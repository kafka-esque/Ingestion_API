.vscode/

# ===============================================================================
# ENVIRONMENT & SECURITY
# ===============================================================================

# Environment variables file (NEVER commit this!)
.env
.env.local
.env.development
.env.test
.env.production

# Application properties with sensitive data
application-*.properties
!application.properties

# ===============================================================================
